PORT=3000
NODE_ENV=development

# --- Site lock (default: OFFLINE on production) ---
# Primary Developer only — set true to serve API normally:
# SITE_LIVE=true
# PRINSTINE_PRIMARY_DEV_KEY=your-long-private-secret-min-16-chars
# Contact: itconsultantbryant@gmail.com (see ../PRIMARY_DEVELOPER.md)

# Comma-separated allowed origins.
# Required when NODE_ENV=production (boot will fail if unset). Local dev can omit.
# Production (live site): include apex + www if you use both.
# CORS_ORIGIN=https://prinstineacademy.org,https://www.prinstineacademy.org
# Local dev:
# CORS_ORIGIN=http://localhost:5173
DATABASE_URL=
# If PostgreSQL is unavailable, the app can fall back to sqlite (wire in db module)
SQLITE_PATH=./data/app.db

# In production: at least 32 characters (Render Blueprint can auto-generate JWT_SECRET)
JWT_SECRET=local-dev-only-replace-with-a-long-random-string-in-production-env
JWT_EXPIRES_IN=7d

# Upload storage:
# - Local is default when cloudinary vars are missing
# - Cloudinary is used when all three vars below are set
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Admin login (set both on Render in production; password is synced on each deploy)
# ADMIN_EMAIL=admin@prinstineacademy.org
# ADMIN_PASSWORD=your-secure-password

# Supabase (optional, for Supabase-backed auth/storage/data features)
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# SUPABASE_DATABASE_URL=postgresql://...
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
