# Production frontend: https://prinstineacademy.org
#
# --- API (production on Vercel) ---
# Recommended: leave VITE_API_URL unset so the browser calls /api on your domain (Vercel proxies to Render).
# Set RENDER_API_URL in Vercel (used at build time for vercel.json proxy):
# RENDER_API_URL=https://your-service.onrender.com
#
# Optional direct API calls (requires CORS on Render). No trailing slash, no /api suffix:
# VITE_API_URL=https://your-service.onrender.com

# Local dev: Vite proxies /api → Express (see vite.config.js). Override proxy target if needed:
# VITE_API_PROXY_TARGET=http://localhost:3000

# Fine-tuning (optional):
# VITE_API_TIMEOUT_MS=1000
# After login, API calls use at least this timeout (dashboard loads many parallel requests):
# VITE_AUTHENTICATED_API_TIMEOUT_MS=30000
# VITE_AUTH_API_TIMEOUT_MS=30000
# Registration / subscribe (slow mobile data — defaults are generous):
# VITE_REGISTRATION_API_TIMEOUT_MS=120000
# VITE_REGISTRATION_RETRY_ATTEMPTS=5
# VITE_SUBSCRIBE_API_TIMEOUT_MS=90000
